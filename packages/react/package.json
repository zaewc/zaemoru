{
  "name": "@zaemoru/react",
  "version": "1.0.1",
  "description": "React adapter for @zaemoru/elements (Lit Web Components).",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@zaemoru/elements": "workspace:*",
    "@zaemoru/tokens": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@zaemoru/elements": "workspace:*"
  },
  "devDependencies": {
    "@zaemoru/tokens": "workspace:*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
